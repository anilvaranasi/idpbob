                </a>
                <a href="javascript:void(0)" ng-click="c.navigateTo('/cve')" class="quick-link">
                    <i class="fa fa-exclamation-circle"></i>
                    <span>CVE Database</span>
                </a>
            </div>
        </div>
        
        <!-- Security Policies -->
