            <div class="metric-value warning">{{data.metrics.openSecurityIncidents}}</div>
            <div class="metric-label">Security Incidents</div>
        </div>
        <div class="metric-card">
            <div class="metric-value good">{{data.metrics.complianceScore}}%</div>
            <div class="metric-label">Compliance Score</div>
        </div>
        <div class="metric-card">
            <div class="metric-value">{{data.metrics.pendingReviews}}</div>
            <div class="metric-label">Pending Reviews</div>
        </div>
    </div>
    
    <div class="dashboard-grid">
