                </a>
                <a href="javascript:void(0)" ng-click="c.navigateTo('/policy-reviews')" class="quick-link">
                    <i class="fa fa-check-square"></i>
                    <span>Policy Reviews</span>
                </a>
            </div>
        </div>
        
        <!-- Compliance & Audits -->
        <div class="dashboard-card">
            <h2><i class="fa fa-balance-scale"></i> Compliance & Audits</h2>
